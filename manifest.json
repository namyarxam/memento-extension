{
  "manifest_version": 3,
  "name": "Memento",
  "key": "",
  "version": "2.0",
  "description": "Save moments from any AI conversation.",
  "permissions": ["activeTab", "scripting", "storage", "identity", "tabs"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://YOUR_PROJECT.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/chat/*",
        "https://gemini.google.com/app/*",
        "https://chatgpt.com/c/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Memento",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
